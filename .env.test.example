# ============================================================
# Homey Playwright — Test Environment Variables
# Copy this file to .env.test and fill in real values.
# NEVER commit .env.test to git (it's in .gitignore)
# ============================================================

# ── Target environment ───────────────────────────────────────
# Set to: http://localhost:3000 (local) or https://qa.homey.app (QA)
BASE_URL=http://localhost:3000

# ── Test user credentials ────────────────────────────────────
# These users must exist in the target environment.
# In QA: use the test seed data users.
# In local: run `rails db:seed:test_users` to create them.

TEST_AGENT_EMAIL=agent@test.homey.com
TEST_AGENT_PASSWORD=

TEST_SOLICITOR_EMAIL=solicitor@test.homey.com
TEST_SOLICITOR_PASSWORD=

TEST_BUYER_EMAIL=buyer@test.homey.com
TEST_BUYER_PASSWORD=

TEST_SELLER_EMAIL=seller@test.homey.com
TEST_SELLER_PASSWORD=

TEST_PANEL_MANAGER_EMAIL=panel@test.homey.com
TEST_PANEL_MANAGER_PASSWORD=

TEST_ADMIN_EMAIL=admin@test.homey.com
TEST_ADMIN_PASSWORD=

# ── Optional: AI features (Phase 2+) ────────────────────────
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
