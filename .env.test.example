# ============================================================
# Homey Playwright — Test Environment Variables
# Copy this file to .env.test and fill in real values.
# NEVER commit .env.test to git (it's in .gitignore)
# ============================================================

# ── Target environment ──────────────────────────────────────────────────────
#
# Use the ENV shorthand to select a pre-configured environment:
#
#   ENV=qa         → https://app.qa.homey.co.uk
#   ENV=preprod    → https://app.preprod.homey.co.uk
#   ENV=reviewapp  → https://homey-tv-86ev94a8a-ccl--6ewkll.herokuapp.com
#   ENV=local      → http://localhost:3000  (default when ENV is unset)
#
# ENV can also be passed inline without editing this file:
#   ENV=qa npx playwright test
#   ENV=preprod npx playwright test --project=chromium-agent
#   ENV=reviewapp npx playwright test tests/enquiries/
#
# If you need a one-off URL override, set BASE_URL directly (overrides ENV):
#   BASE_URL=https://my-branch.herokuapp.com npx playwright test
#
ENV=qa

# BASE_URL=https://app.qa.homey.co.uk   # Uncomment to override ENV resolution

# ── Test user credentials ───────────────────────────────────────────────────
# These users must exist in the target environment.
# All four environments (QA, PrePROD, ReviewApp, local) use the same
# TEST_* credential names — switch credentials by swapping ENV above.

TEST_AGENT_EMAIL=agent@test.homey.co.uk
TEST_AGENT_PASSWORD=

TEST_SOLICITOR_EMAIL=solicitor@test.homey.co.uk
TEST_SOLICITOR_PASSWORD=

TEST_BUYER_EMAIL=buyer@test.homey.co.uk
TEST_BUYER_PASSWORD=

TEST_SELLER_EMAIL=seller@test.homey.co.uk
TEST_SELLER_PASSWORD=

TEST_PANEL_MANAGER_EMAIL=panel@test.homey.co.uk
TEST_PANEL_MANAGER_PASSWORD=

TEST_ADMIN_EMAIL=admin@test.homey.co.uk
TEST_ADMIN_PASSWORD=

# ── AI features (Phase 3+) ──────────────────────────────────────────────────
# OPENAI_API_KEY=sk-...

# ── Visual regression (Phase 5) ─────────────────────────────────────────────
# PERCY_TOKEN=...
# APPLITOOLS_API_KEY=...

# ── Contract testing (Phase 6) ──────────────────────────────────────────────
# PACT_BROKER_BASE_URL=https://your-broker.pactflow.io
# PACT_BROKER_TOKEN=...

# ── Performance (Phase 7) ───────────────────────────────────────────────────
# PERFORMANCE_REQUIRED=true   # Uncomment to make perf failures block the run
